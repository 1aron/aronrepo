{
    "private": true,
    "type": "module",
    "packageManager": "pnpm@11.9.0",
    "devEngines": {
        "packageManager": {
            "name": "pnpm",
            "version": "11.9.0",
            "onFail": "ignore"
        }
    },
    "scripts": {
        "postinstall": "husky install",
        "build": "turbo run build --filter=\"./packages/*\"",
        "check": "pnpm run commit-check && turbo run test lint type-check --filter=\"./packages/*\"",
        "test": "turbo run test --filter=\"./packages/*\"",
        "lint": "turbo run lint --filter=\"./packages/*\"",
        "type-check": "turbo run type-check --filter=\"./packages/*\"",
        "commit-check": "node scripts/commit-check.mjs",
        "release": "semantic-release"
    },
    "engines": {
        "node": "^26"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/1aron/aronrepo.git"
    },
    "dependencies": {
        "@commitlint/cli": "^21.1.0",
        "@commitlint/lint": "^21.1.0",
        "@semantic-release/commit-analyzer": "^13.0.1",
        "@semantic-release/github": "^12.0.0",
        "@semantic-release/release-notes-generator": "^14.1.0",
        "@types/fs-extra": "^11.0.4",
        "@types/node": "^26.0.1",
        "@types/semver": "^7.7.1",
        "eslint": "^10.5.0",
        "husky": "^9.1.7",
        "semantic-release": "^25.0.2",
        "tsdown": "^0.22.3",
        "tsx": "^4.21.0",
        "turbo": "^2.6.3",
        "typescript": "^6.0.3",
        "vitest": "^4.0.15"
    },
    "devDependencies": {
        "aronrepo": "workspace:^",
        "@aronrepo/commitlint-config": "workspace:^",
        "@aronrepo/conventional-changelog-config": "workspace:^",
        "@aronrepo/conventional-commits": "workspace:^",
        "@aronrepo/eslint-config": "workspace:^",
        "@aronrepo/semantic-release-config": "workspace:^",
        "@aronrepo/semantic-release-pnpm": "workspace:^",
        "@types/js-yaml": "^4.0.9"    }
}
