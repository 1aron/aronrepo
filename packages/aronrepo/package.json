{
    "name": "aronrepo",
    "version": "0.0.0",
    "type": "module",
    "license": "MIT",
    "description": "Facade package for the Aronrepo monorepo toolchain.",
    "repository": {
        "type": "git",
        "url": "https://github.com/1aron/aronrepo.git",
        "directory": "packages/aronrepo"
    },
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "test": "vitest",
        "type-check": "tsc --noEmit",
        "lint": "eslint"
    },
    "peerDependencies": {
        "typescript": "*"
    },
    "dependencies": {
        "@aronrepo/commitlint-config": "workspace:^",
        "@aronrepo/conventional-changelog-config": "workspace:^",
        "@aronrepo/conventional-commits": "workspace:^",
        "@aronrepo/eslint-config": "workspace:^",
        "@aronrepo/prettier-config": "workspace:^",
        "@aronrepo/semantic-release-config": "workspace:^"
    }
}
