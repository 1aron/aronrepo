{
    "name": "@aronrepo/semantic-release-pnpm",
    "version": "0.0.0",
    "type": "module",
    "license": "MIT",
    "description": "Semantic-release plugin for publishing pnpm workspace packages.",
    "repository": {
        "type": "git",
        "url": "https://github.com/1aron/aronrepo.git",
        "directory": "packages/semantic-release-pnpm"
    },
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "test": "vitest",
        "type-check": "tsc --noEmit",
        "lint": "eslint"
    },
    "dependencies": {
        "@actions/core": "^3.0.1",
        "@semantic-release/error": "^4.0.0",
        "execa": "^9.6.1",
        "fs-extra": "^11.3.5",
        "normalize-url": "^9.0.1",
        "semver": "^7.7.3"
    },
    "peerDependencies": {
        "semantic-release": "*"
    }
}
