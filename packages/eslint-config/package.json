{
    "name": "@aronrepo/eslint-config",
    "version": "0.0.0",
    "type": "module",
    "license": "MIT",
    "description": "ESLint flat config for Aronrepo packages.",
    "repository": {
        "type": "git",
        "url": "https://github.com/1aron/aronrepo.git",
        "directory": "packages/eslint-config"
    },
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "test": "vitest",
        "type-check": "tsc --noEmit",
        "lint": "eslint"
    },
    "dependencies": {
        "@eslint/js": "^9.39.1",
        "typescript-eslint": "^8.50.0"
    },
    "peerDependencies": {
        "eslint": "*",
        "typescript": "*"
    }
}
