        }
    },
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "test": "vitest",
        "type-check": "tsc --noEmit",
        "lint": "eslint"
    }
}
