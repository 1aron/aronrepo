{
    "name": "@aronrepo/conventional-commits",
    "version": "0.0.0",
    "type": "module",
    "license": "MIT",
    "description": "Aronrepo conventional commit types, release rules, and changelog groups.",
    "repository": {
        "type": "git",
        "url": "https://github.com/1aron/aronrepo.git",
        "directory": "packages/conventional-commits"
    },
    "sideEffects": false,
